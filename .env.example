# Zoo Exchange — regulated-provider wiring (Vite-native)
#
# Copy to `.env.local` and fill with values from
# `~/work/liquidity/contracts/script/DeployProvider.s.sol`.

VITE_RPC_URL=https://api.zoo.network/rpc

# Regulated provider (adapter implementing IRegulatedProvider)
VITE_LIQUIDITY_ADAPTER=
VITE_LIQUIDITY_ROUTER=
VITE_LIQUIDITY_NAME=Liquidity.io
VITE_LIQUIDITY_ONBOARDING_URL=https://onboard.liquidity.io
VITE_LIQUIDITY_VERIFY_URL=https://verify.liquidity.io
